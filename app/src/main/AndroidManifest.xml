<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- صلاحيات التخزين الأساسية -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <!-- صلاحية الوصول الكامل لجميع الملفات (Android 11+) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <uses-feature android:glEsVersion="0x00030001" android:required="true" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="V-Viewer"
        android:theme="@style/Theme.VViewer"
        android:extractNativeLibs="true"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name="com.vviewer.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="landscape">
            <meta-data android:name="android.app.lib_name" android:value="vviewer" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.vviewer.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.VViewer" />

        <activity
            android:name="com.vviewer.TerminalActivity"
            android:exported="false"
            android:theme="@style/Theme.VViewer" />

    </application>
</manifest>
