<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF0A0A1A"
                android:centerColor="#FF12122E"
                android:endColor="#FF1A1A3E"
                android:angle="135" />
        </shape>
    </item>
    <item
        android:width="200dp"
        android:height="200dp"
        android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:startColor="#4D4DFF"
                android:endColor="#1A1A4D"
                android:type="radial"
                android:gradientRadius="50%" />
            <stroke
                android:width="1dp"
                android:color="#6D6DFF"
                android:dashWidth="10dp"
                android:dashGap="5dp" />
        </shape>
    </item>
</layer-list>
